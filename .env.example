# API gateway URL — used for WebSocket connections in dev (REST uses CRA proxy).
# In production, serve the static build behind a reverse proxy that forwards
# /api/* and /ws to the gateway, or set this at build time.
REACT_APP_GATEWAY_BASE_URL=http://localhost:8000

# Optional synonym for REACT_APP_GATEWAY_BASE_URL (WebSocket fallback only).
# REACT_APP_API_BASE_URL=http://localhost:8000
